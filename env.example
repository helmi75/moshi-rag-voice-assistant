# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs
# Commande: cp env.example .env

# Clé API OpenRouter (https://openrouter.ai/keys) — le cerveau de l'assistant.
# OpenRouter donne accès à Claude, GPT, Gemini, Llama, Mistral, DeepSeek... avec
# une seule clé, et propose des modèles gratuits pour tester sans dépenser.
OPENROUTER_API_KEY="sk-or-v1-..."

# Modèle utilisé (catalogue complet : https://openrouter.ai/models) :
#   openrouter/free                     -> gratuit, choisi automatiquement (défaut)
#   anthropic/claude-sonnet-5           -> Claude
#   openai/gpt-4o-mini                  -> GPT
#   google/gemini-2.0-flash-001         -> Gemini
#   meta-llama/llama-3.3-70b-instruct   -> open source
# LLM_MODEL=openrouter/free

# En-têtes d'attribution optionnels (visibles dans le classement OpenRouter)
# OPENROUTER_SITE_URL=https://mondomaine.fr
# OPENROUTER_APP_NAME=Mon assistant vocal

# Configuration Twilio
TWILIO_ACCOUNT_SID="your_account_sid_here"
TWILIO_AUTH_TOKEN="your_auth_token_here"
# Numéro Twilio du tenant de démonstration (format E.164)
TWILIO_NUMBER=+33100000000

# ── Pipeline vocal ────────────────────────────────────────────────
# "gather" (défaut) : boucle Say/Gather Twilio. Simple et fiable, aucune clé sup.
#            La voix par défaut est une voix NEURONALE Amazon (Léa, fr), naturelle
#            et incluse dans Twilio — voir TWILIO_VOICE plus bas.
# "stream" : audio temps réel (Media Streams + Pipecat). Nécessite une clé Deepgram
#            (STT) + un TTS temps réel. ATTENTION : le TTS Kyutai (Pocket TTS) en
#            français exige un GPU ; sur CPU il est trop lent (5-10 s de latence) —
#            en mode stream, utiliser TTS_PROVIDER=cartesia.
VOICE_MODE=gather

# Voix du <Say> Twilio en mode gather. Défaut : Polly.Lea-Neural (française, neuronale).
# Autres ex. : Polly.Remi-Neural (homme, fr). Mettre vide pour la voix standard.
# TWILIO_VOICE=Polly.Lea-Neural

# URL WebSocket publique annoncée à Twilio en mode stream
# (votre domaine derrière Caddy, ex. wss://assistant.mondomaine.fr/ws/voice ;
#  en test derrière ngrok : wss://xxxx.ngrok-free.app/ws/voice)
# PUBLIC_WS_URL=wss://assistant.mondomaine.fr/ws/voice

# STT streaming français (https://deepgram.com — crédits gratuits à l'inscription)
# DEEPGRAM_API_KEY=...
# DEEPGRAM_MODEL=nova-3

# ── TTS (mode stream) ─────────────────────────────────────────────
# "pocket" (défaut) : Kyutai Pocket TTS, la voix de la famille Unmute, sur CPU,
#                     sans clé. Premier appel : ~30-60 s de téléchargement du modèle.
# "cartesia" : API payante (voix française du catalogue Cartesia).
# TTS_PROVIDER=pocket
# Voix Pocket TTS : nom préréglé (estelle = voix française du site Unmute), ou
# un chemin/URL/hf:// vers un extrait audio pour CLONER une voix.
# POCKET_TTS_VOICE=estelle
# POCKET_TTS_LANGUAGE=french_24l
# Périphérique d'inférence : auto (défaut : GPU si dispo, sinon CPU), cuda, ou cpu.
# Le GPU rend Pocket TTS temps réel (fin de la voix saccadée du CPU). Voir docs/GPU.md
# et lancer avec : docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d --build
# POCKET_TTS_DEVICE=auto

# Alternative TTS Cartesia (si TTS_PROVIDER=cartesia)
# CARTESIA_API_KEY=...
# CARTESIA_VOICE_ID=...
