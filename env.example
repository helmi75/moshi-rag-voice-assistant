# Configuration Twilio
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs
# Commande: cp env.example .env

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_NUMBER=+1234567890

# Configuration Moshi
# Modèle HuggingFace à utiliser (options: kyutai/moshika-pytorch-bf16, kyutai/moshiko-pytorch-bf16)
MOSHI_HF_REPO=kyutai/moshika-pytorch-bf16

