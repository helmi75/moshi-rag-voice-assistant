# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs
# Commande: cp env.example .env

# Clé API OpenRouter (https://openrouter.ai/keys) — le cerveau de l'assistant.
# OpenRouter donne accès à Claude, GPT, Gemini, Llama, Mistral, DeepSeek... avec
# une seule clé, et propose des modèles gratuits pour tester sans dépenser.
OPENROUTER_API_KEY="sk-or-v1-..."

# Modèle utilisé (catalogue complet : https://openrouter.ai/models) :
#   openrouter/free                     -> gratuit, choisi automatiquement (défaut)
#   anthropic/claude-sonnet-5           -> Claude
#   openai/gpt-4o-mini                  -> GPT
#   google/gemini-2.0-flash-001         -> Gemini
#   meta-llama/llama-3.3-70b-instruct   -> open source
# LLM_MODEL=openrouter/free

# En-têtes d'attribution optionnels (visibles dans le classement OpenRouter)
# OPENROUTER_SITE_URL=https://mondomaine.fr
# OPENROUTER_APP_NAME=Mon assistant vocal

# Configuration Twilio
TWILIO_ACCOUNT_SID="your_account_sid_here"
TWILIO_AUTH_TOKEN="your_auth_token_here"
# Numéro Twilio du tenant de démonstration (format E.164)
TWILIO_NUMBER=+33100000000

# ── Pipeline vocal ────────────────────────────────────────────────
# "gather" (défaut) : boucle Say/Gather Twilio, aucune clé supplémentaire.
# "stream" : audio temps réel (Media Streams + Pipecat), latence ~1 s,
#            nécessite les clés Deepgram + Cartesia ci-dessous.
VOICE_MODE=gather

# URL WebSocket publique annoncée à Twilio en mode stream
# (votre domaine derrière Caddy, ex. wss://assistant.mondomaine.fr/ws/voice)
# PUBLIC_WS_URL=wss://assistant.mondomaine.fr/ws/voice

# STT streaming français (https://deepgram.com)
# DEEPGRAM_API_KEY=...
# DEEPGRAM_MODEL=nova-3

# TTS streaming français (https://cartesia.ai — choisir une voix française)
# CARTESIA_API_KEY=...
# CARTESIA_VOICE_ID=...
